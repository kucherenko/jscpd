#!/usr/bin/env bash
# Convenient wrapper that always uses --release

cd "$(dirname "$0")"

if [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
    echo "Usage: ./cpd-fast [path] [options]"
    echo ""
    echo "Examples:"
    echo "  ./cpd-fast ../fixtures -r time"
    echo "  ./cpd-fast ../fixtures -r console,time"
    echo "  ./cpd-fast . -r json"
    echo ""
    echo "This wrapper automatically uses 'cargo run --release --bin cpd'"
    echo "so you get optimized performance (~90ms instead of ~600ms)."
    exit 0
fi

echo "Running: cargo run --release --bin cpd -- $@"
echo ""

exec cargo run --release --bin cpd -- "$@"
